{
    "name": "paulmercs/filament-sileo-notifications",
    "description": "Sileo toast bridge for Filament notifications with optional global generic action messages.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Paulmercs\\FilamentSileoNotifications\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paulmercs\\FilamentSileoNotifications\\FilamentSileoNotificationsServiceProvider"
            ]
        }
    }
}

